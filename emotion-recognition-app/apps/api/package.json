{
  "name": "@emotion-recognition/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "predev": "npm --workspace @emotion-recognition/shared run build",
    "dev": "tsx watch --tsconfig tsconfig.dev.json src/server.ts",
    "worker": "tsx watch --tsconfig tsconfig.dev.json src/worker.ts",
    "build": "npm --workspace @emotion-recognition/shared run build && prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit --pretty false",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@emotion-recognition/shared": "file:../../packages/shared",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.21.2",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
